# Axiom Core production environment variables.
#
# Installed by scripts/deploy_axiom_cloud.ps1 → /etc/axiom-core/env (mode 0640)
# on first deploy. After install, edit /etc/axiom-core/env with REAL values and
# run `systemctl restart axiom-core` to pick them up.
#
# This file (env.example) ships in git and must NEVER contain real secrets.

# ── Cloud mode ───────────────────────────────────────────────────────────────
AXIOM_CLOUD_MODE=1
AXIOM_PUBLIC_HOSTNAME=jeffxu.cc

# ── Web auth (required when AXIOM_CLOUD_MODE=1) ──────────────────────────────
AXIOM_WEB_USER=change-me
AXIOM_WEB_PASSWORD=change-me-to-a-long-strong-password

# Session signing key. MUST be at least 32 chars and independent of the
# login password. Generate with:  openssl rand -hex 32
AXIOM_SESSION_SECRET=change-me-to-32-plus-random-chars

# Optional: an independent HMAC key for the ALTCHA proof-of-work widget. If
# unset, ALTCHA reuses AXIOM_SESSION_SECRET.
# ALTCHA_HMAC_KEY=

# Session TTL. Defaults to 8 hours if neither is set.
# AXIOM_SESSION_TTL_HOURS=8
# AXIOM_SESSION_TTL_SECONDS=28800

# ── Feishu (Lark) bot ────────────────────────────────────────────────────────
# Required for /api/feishu/events to authenticate incoming callbacks.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# ── Optional debug toggles ───────────────────────────────────────────────────
# Enables /api/altcha/debug. Leave 0 in production.
AXIOM_ALTCHA_DEBUG=0
